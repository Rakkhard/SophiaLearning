# Student Grade Calculator Program

num_grades = int(input("Enter number of grades: "))

total = 0

for i in range(num_grades):
  
    grade = int(input(f"Enter grade {i+1}: "))
    
    
    total += grade

average = total / num_grades

if average >= 90:
    letter = "A"
elif average >= 80:
    letter = "B"
elif average >= 70:
    letter = "C"
elif average >= 60:
    letter = "D"
else:
    letter = "F"

print("Average:", average)
print("Letter Grade:", letter)